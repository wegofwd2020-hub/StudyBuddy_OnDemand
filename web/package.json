{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:student": "playwright test --project=persona-student",
    "test:e2e:teacher": "playwright test --project=persona-teacher",
    "test:e2e:admin": "playwright test --project=persona-admin",
    "test:e2e:personas": "playwright test --project=persona-student --project=persona-teacher --project=persona-admin",
    "test:e2e:report": "playwright show-report",
    "gen:types": "openapi-typescript openapi.json -o lib/api/types.gen.ts",
    "api:check": "npm run gen:types && git diff --exit-code lib/api/types.gen.ts"
  },
  "dependencies": {
    "@auth0/nextjs-auth0": "4.16.1",
    "@base-ui/react": "1.3.0",
    "@hookform/resolvers": "5.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "5.96.2",
    "axios": "1.13.6",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "diff": "^8.0.4",
    "lucide-react": "1.7.0",
    "mermaid": "^11.14.0",
    "next": "16.2.3",
    "next-intl": "4.8.3",
    "next-themes": "0.4.6",
    "papaparse": "5.5.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "7.72.0",
    "react-markdown": "^10.1.0",
    "recharts": "3.8.1",
    "remark-gfm": "^4.0.1",
    "shadcn": "4.1.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "1.4.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "4.2.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/diff": "^7.0.2",
    "@types/node": "20.19.37",
    "@types/papaparse": "5.5.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.3",
    "jsdom": "29.0.1",
    "openapi-typescript": "^7.13.0",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  }
}
